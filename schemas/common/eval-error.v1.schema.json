{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poolside.ai/schemas/common/eval-error.v1.schema.json",
  "title": "Eval robot error v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ok", "phase", "exit_code", "error", "suggested_command"],
  "properties": {
    "schema_version": { "const": "eval-error.v1" },
    "ok": { "const": false },
    "phase": { "enum": ["args", "suite", "matrix"] },
    "exit_code": { "type": "integer", "minimum": 1 },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message"],
      "properties": {
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "suggested_command": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    }
  }
}
