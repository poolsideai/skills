{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poolside.ai/schemas/common/eval-dry-run-summary.v1.schema.json",
  "title": "Eval dry-run robot summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ok", "suite", "filters", "counts", "fixtures", "runs", "replays"],
  "properties": {
    "schema_version": { "const": "eval-dry-run-summary.v1" },
    "ok": { "type": "boolean" },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases", "arms"],
      "properties": {
        "cases": { "anyOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string", "minLength": 1 } }] },
        "arms": { "anyOf": [{ "type": "null" }, { "type": "array", "items": { "type": "string", "minLength": 1 } }] }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases_loaded", "runs_planned", "fixture_invalid_cases", "run_preview_failures", "replay_failures", "failures"],
      "properties": {
        "cases_loaded": { "type": "integer", "minimum": 0 },
        "runs_planned": { "type": "integer", "minimum": 0 },
        "fixture_invalid_cases": { "type": "integer", "minimum": 0 },
        "run_preview_failures": { "type": "integer", "minimum": 0 },
        "replay_failures": { "type": "integer", "minimum": 0 },
        "failures": { "type": "integer", "minimum": 0 }
      }
    },
    "fixtures": { "type": "array", "items": { "$ref": "#/$defs/fixture" } },
    "runs": { "type": "array", "items": { "$ref": "#/$defs/run" } },
    "replays": { "type": "array", "items": { "$ref": "#/$defs/replay" } }
  },
  "$defs": {
    "string_list": { "type": "array", "items": { "type": "string" } },
    "argv": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "status", "arms", "problems"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["ok", "invalid"] },
        "arms": { "$ref": "#/$defs/string_list" },
        "problems": { "$ref": "#/$defs/string_list" }
      }
    },
    "run_fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "problems", "skill_materialized", "scratch_kept", "scratch", "workspace"],
      "properties": {
        "status": { "enum": ["ok", "invalid", "error"] },
        "problems": { "$ref": "#/$defs/string_list" },
        "skill_materialized": { "type": "boolean" },
        "scratch_kept": { "type": "boolean" },
        "scratch": { "type": ["string", "null"] },
        "workspace": { "type": ["string", "null"] }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "label", "case_id", "case_dir", "skill", "arm", "model_class", "agent_name", "with_skill", "fixture", "pool_command", "environment", "validator", "manifest_preview"],
      "properties": {
        "ok": { "type": "boolean" },
        "run_id": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "case_id": { "type": "string", "minLength": 1 },
        "case_dir": { "type": "string", "minLength": 1 },
        "skill": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        },
        "arm": { "type": "string", "minLength": 1 },
        "model_class": { "type": "string", "minLength": 1 },
        "agent_name": { "type": "string", "minLength": 1 },
        "with_skill": { "type": "boolean" },
        "fixture": { "$ref": "#/$defs/run_fixture" },
        "pool_command": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["argv", "shell", "debt"],
              "properties": {
                "argv": { "$ref": "#/$defs/argv" },
                "shell": { "type": "string", "minLength": 1 },
                "debt": { "type": "array", "items": { "type": "object" } }
              }
            }
          ]
        },
        "environment": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["home", "xdg_state_home", "poolside_token", "credentials"],
              "properties": {
                "home": { "type": ["string", "null"] },
                "xdg_state_home": { "type": ["string", "null"] },
                "poolside_token": { "enum": ["not-used-in-dry-run"] },
                "credentials": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "validator": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["argv", "expected_status"],
              "properties": {
                "argv": { "$ref": "#/$defs/argv" },
                "expected_status": { "type": "string", "minLength": 1 }
              }
            }
          ]
        },
        "manifest_preview": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["valid", "errors", "manifest"],
              "properties": {
                "valid": { "type": "boolean" },
                "errors": { "$ref": "#/$defs/string_list" },
                "manifest": { "type": "object" }
              }
            }
          ]
        }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": true,
      "required": ["case_id", "status", "expected_status"],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "fail", "skipped"] },
        "expected_status": { "type": "string", "minLength": 1 }
      }
    }
  }
}
