case "${1:-}" in
  --robot-triage)
    cat <<'JSON'
{
  "status": "ok",
  "recommendations": [
    {
      "id": "bd-301",
      "title": "Optimize database query for user profiles",
      "status": "open",
      "ready": true,
      "blocked": false,
      "labels": ["performance"],
      "pagerank": 0.25,
      "betweenness": 0.18
