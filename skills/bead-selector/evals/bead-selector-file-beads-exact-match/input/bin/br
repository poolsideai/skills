#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  ready)
    cat <<'JSON'
[
  { "id": "bd-305", "title": "Implement user handler authentication" },
  { "id": "bd-303", "title": "Update docs mentioning user.ts authentication" }
]
JSON
    ;;
  list)
    cat <<'JSON'
[
  { "id": "bd-301", "status": "open" },
  { "id": "bd-305", "status": "open" }
]
JSON
    ;;
  *)
    echo '{"ok":true,"note":"fixture br does not mutate"}'
    ;;
esac
