      "id": "bd-302",
      "title": "URGENT: Customer blocking issue",
      "status": "open",
      "ready": false,
      "blocked": true,
      "blocked_by": ["bd-301"],
      "priority": 950,
      "pagerank": 0.10,
      "unblocks": ["bd-303"]
    },
    {
      "id": "bd-303",
      "title": "Refactor legacy authentication module",
      "status": "open",
      "ready": true,
      "blocked": false,
