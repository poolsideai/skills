#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  ready)
    cat <<'JSON'
[
  { "id": "bd-302", "title": "Fix metric calculation pipeline" },
  { "id": "bd-305", "title": "Update documentation examples" }
]
JSON
    ;;
  list)
    cat <<'JSON'
[
  { "id": "bd-301", "status": "open" },
  { "id": "bd-302", "status": "open" },
  { "id": "bd-305", "status": "open" }
]
JSON
    ;;
  *)
    echo '{"ok":true,"note":"fixture br does not mutate"}'
    ;;
esac
