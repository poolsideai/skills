#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  ready)
    cat <<'JSON'
[
  { "id": "bd-301", "title": "Auth refactor core module" },
  { "id": "bd-305", "title": "Update auth documentation" }
]
JSON
    ;;
  list)
    cat <<'JSON'
[
  { "id": "bd-301", "status": "open" },
  { "id": "bd-303", "status": "open" },
  { "id": "bd-305", "status": "open" }
]
JSON
    ;;
  *)
    echo "{\"ok\":true,\"note\":\"fixture br does not mutate\"}"
    ;;
esac
