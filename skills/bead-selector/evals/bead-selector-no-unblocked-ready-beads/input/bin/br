#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  ready)
    cat <<'JSON'
[
  
]
JSON
    ;;
  list)
    cat <<'JSON'
[
  { "id": "bd-301", "status": "open" },
  { "id": "bd-305", "status": "open" },
  { "id": "bd-308", "status": "in_progress" }
]
JSON
    ;;
  *)
    echo "{\"ok\":true,\"note\":\"fixture br does not mutate\"}"
    ;;
esac
