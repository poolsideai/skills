#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  ready)
    cat <<'JSON'
[
  { "id": "bd-101", "title": "Stabilize graph traversal" },
  { "id": "bd-102", "title": "Fix validation edge case" }
]
JSON
    ;;
  list)
    cat <<'JSON'
[
  { "id": "bd-101", "status": "open" },
  { "id": "bd-102", "status": "open" }
]
JSON
    ;;
  *) 
    echo '{"ok":true,"note":"fixture br does not mutate"}'
    ;;
esac
