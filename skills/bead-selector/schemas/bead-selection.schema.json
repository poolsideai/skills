{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poolside.ai/schemas/bead-selection.v1.schema.json",
  "title": "bead-selection.v1",
  "type": "object",
  "required": [
    "schema_version",
    "request",
    "mode",
    "selected_bead",
    "commands_used",
    "graph_evidence",
    "next_action",
    "caveats"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "bead-selection.v1" },
    "request": { "type": "string", "minLength": 5, "maxLength": 300 },
    "mode": {
      "type": "string",
      "enum": ["next", "triage", "plan", "search", "cycle_break", "label_focus", "none"]
    },
    "selected_bead": {
      "type": "object",
      "required": ["id", "title", "status", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^(bd-[A-Za-z0-9._:-]+|none)$" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "status": { "type": "string", "minLength": 1, "maxLength": 60 },
        "reason": { "type": "string", "minLength": 20, "maxLength": 1000 }
      }
    },
    "commands_used": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["command", "why"],
        "additionalProperties": false,
        "properties": {
          "command": { "type": "string", "minLength": 3, "maxLength": 300 },
          "why": { "type": "string", "minLength": 8, "maxLength": 300 }
        }
      }
    },
    "graph_evidence": {
      "type": "object",
      "required": ["primary_signal", "signals", "blockers", "rejected_candidates"],
      "additionalProperties": false,
      "properties": {
        "primary_signal": { "type": "string", "minLength": 3, "maxLength": 80 },
        "signals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "object",
            "required": ["bead_id", "metric", "value", "source_command"],
            "additionalProperties": false,
            "properties": {
              "bead_id": { "type": "string", "pattern": "^(bd-[A-Za-z0-9._:-]+|none)$" },
              "metric": { "type": "string", "minLength": 2, "maxLength": 80 },
              "value": {},
              "source_command": { "type": "string", "minLength": 3, "maxLength": 300 }
            }
          }
        },
        "blockers": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "required": ["id", "blocks"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^bd-[A-Za-z0-9._:-]+$" },
              "blocks": {
                "type": "array",
                "items": { "type": "string", "pattern": "^bd-[A-Za-z0-9._:-]+$" }
              }
            }
          }
        },
        "rejected_candidates": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "required": ["id", "reason"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^bd-[A-Za-z0-9._:-]+$" },
              "reason": { "type": "string", "minLength": 10, "maxLength": 400 }
            }
          }
        }
      }
    },
    "next_action": {
      "type": "object",
      "required": ["command", "destructive"],
      "additionalProperties": false,
      "properties": {
        "command": { "type": "string", "minLength": 2, "maxLength": 300 },
        "destructive": { "type": "boolean" }
      }
    },
    "caveats": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 240 }
    }
  }
}
