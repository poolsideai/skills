      { "path": "bug-report.md", "why": "failing command and observed vs expected output" }
    ],
    "commands": ["bun test test/slugify.test.ts"],
    "logs": []
  },
  "scope": {
    "paths": ["src/slugify.ts"],
    "max_files_to_modify": 1
  },
  "constraints": {
