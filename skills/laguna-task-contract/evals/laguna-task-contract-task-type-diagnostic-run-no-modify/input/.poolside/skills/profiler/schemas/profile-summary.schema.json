{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poolside.ai/schemas/skills/profiler/profile-summary.schema.json",
  "title": "profile-summary.v1",
  "type": "object",
  "properties": {
    "top_functions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "function_name": { "type": "string" },
          "cpu_percent": { "type": "number" },
          "call_count": { "type": "integer" }
        },
        "required": ["function_name", "cpu_percent", "call_count"]
      }
    },
    "total_samples": { "type": "integer" },
    "profiler_version": { "type": "string" }
  },
  "required": ["top_functions", "total_samples", "profiler_version"]
}
